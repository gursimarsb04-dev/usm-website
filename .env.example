# ── Supabase (create free project at supabase.com → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# ── Sanity (create free project at sanity.io/manage) ──
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# ── Stripe (event ticketing) — dashboard.stripe.com/apikeys ──
# Leave unset and paid registrations fall back to a free RSVP.
STRIPE_SECRET_KEY=            # sk_test_... or sk_live_...
NEXT_PUBLIC_BASE_URL=         # optional; used for Stripe redirect URLs if origin is unavailable

# ── Board pages password gate ──
BOARD_PASSWORD=change-me

# ── Mailchimp (phase 2 — news sync) ──
MAILCHIMP_API_KEY=
